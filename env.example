# Copy to .env.local for local dev with `vercel dev`, or set this in your
# Vercel project's Environment Variables for production.
#
# Get a free key at https://aistudio.google.com/apikey (Google AI Studio) —
# no credit card required for the free tier.
#
# NEVER commit your real key or prefix it with VITE_ (that would ship it to
# the browser). It must stay server-side only, read by api/ai.js.
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional. Comma-separated list of origins allowed to call /api/ai
# cross-origin (e.g. a preview deployment sharing this backend). Leave unset
# for a normal single-deployment setup — the SPA calling its own /api/ai
# route is same-origin and doesn't need this. Do NOT set this to "*"; that
# would let any website on the internet spend your Gemini quota.
ALLOWED_ORIGINS=https://concourse26.vercel.app
